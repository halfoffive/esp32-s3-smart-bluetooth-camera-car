# =============================================================================
# .gitignore
# 本文件按工具链/产物类型分段组织，每段以中文注释说明用途。
# 注意：.gitignore 只忽略"编译产物"与"本地配置"，不会忽略源代码文件。
# =============================================================================

# -----------------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------------
# Rust 编译产物
target/
# Rust 备份文件
**/*.rs.bk
# 注意：Cargo.lock 仅 library 工程忽略；本项目 app/rust 是可执行 crate，
# 需要锁定依赖版本以保证可复现构建，故此处【不】忽略 Cargo.lock。

# -----------------------------------------------------------------------------
# Flutter / Dart
# -----------------------------------------------------------------------------
# Dart 工具链缓存与产物
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
# Flutter 构建产物（仅根目录 build/）
/build/
# 自动生成的插件注册文件
**/generated_plugin_registrant.dart
# Flutter 项目元数据（可选忽略：部分团队选择保留以固定 SDK 信息，
# 此处选择忽略以避免 SDK 版本差异带来的噪声）
.metadata
# app 目录下的 Flutter 插件依赖描述
app/.flutter-plugins*
# Flutter 平台原生目录（由 flutter create . 在本地/CI 生成，不进入版本控制）
app/android/
app/ios/
app/linux/
app/macos/
app/windows/
# flutter_rust_bridge 生成绑定
app/lib/src/rust/
app/rust/src/frb_generated.rs
# Dart 依赖锁定（本仓库选择不锁定 App 层依赖版本）
app/pubspec.lock

# -----------------------------------------------------------------------------
# PlatformIO
# -----------------------------------------------------------------------------
# PlatformIO 构建缓存与依赖
.pio/
.pioenvs/
.piolibdeps
# firmware 工程的 PlatformIO 产物
firmware/.pio/

# -----------------------------------------------------------------------------
# IDE / 编辑器
# -----------------------------------------------------------------------------
.vscode/
.idea/
# Vim 交换文件
*.swp
*.swo
*~
# macOS 目录元数据
.DS_Store

# -----------------------------------------------------------------------------
# 构建产物（本地）
# -----------------------------------------------------------------------------
# 二进制 / ELF / 链接映射等编译产物
*.bin
*.elf
*.map
# 保留 GitHub Actions 工作流文件（不应被 *.bin 等规则误伤）
!.github/
!.github/**
# 例外：不忽略源文件（.gitignore 只忽略编译产物，不会忽略 partitions.csv 等源文件）
# 如 firmware/partitions.csv、*.csv、*.proto 等均不受影响
!firmware/partitions.csv

# -----------------------------------------------------------------------------
# 本地密钥 / 环境变量
# -----------------------------------------------------------------------------
.env
.env.local
secrets/
*.key

# -----------------------------------------------------------------------------
# 其它
# -----------------------------------------------------------------------------
# 前端/工具链依赖（万一有工具链用到）
node_modules/
# 测试覆盖率报告
coverage/

# 本地临时日志（flutter/dart analyze、flutter build 等输出重定向）
*.log

# Oh My Open Agent
.omo/
